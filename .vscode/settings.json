{
  "files.associations": {
    "*.geogebra": "json"
  },
  "json.schemas": [
    {
      "fileMatch": [
        "*.geogebra"
      ],
      "url": "./.vscode/geogebra.schema.json"
    }
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "prettier.printWidth": 120,
  "prettier.tabWidth": 2
}
